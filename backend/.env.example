# Application
APP_ENV=development
APP_DEBUG=true
# Set to the tunnel URL when using shopify app dev, e.g. https://abc123.trycloudflare.com
# Set to https://optimo-virtual-try-on.vercel.app in production
APP_URL=https://tractor-species-breach-spent.trycloudflare.com
SECRET_KEY=your-secret-key-here

# Database (Local Docker)
DATABASE_URL=postgresql://dev:dev123@localhost:5432/virtual_tryon_dev

# Redis (Local Docker)
REDIS_URL=redis://localhost:6379/0
PHOTO_CACHE_TTL_SECONDS=3600
MEASUREMENT_CACHE_TTL_SECONDS=86400
TRYON_RESULT_TTL_SECONDS=3600

# Shopify (Get from Shopify Partner Dashboard)
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SCOPES=read_products,read_themes,write_script_tags
# Billing mode:
# - manual: app creates charges via Billing API (required for custom usage overage charging)
# - managed: Shopify-managed pricing page (Billing API charge creation is blocked)
SHOPIFY_BILLING_MODE=manual
SHOPIFY_API_VERSION=2026-01
UNINSTALL_FALLBACK_DELETE_DAYS=30
STORE_DELETION_SCHEDULER_ENABLED=true
STORE_DELETION_SCHEDULER_INTERVAL_MINUTES=15

# Image Generation Provider
# Supported values: gemini | replicate | seedream
IMAGE_PROVIDER=gemini

# Google Vertex AI (Gemini)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Path to service-account JSON file available on disk or mounted secret path.
GOOGLE_APPLICATION_CREDENTIALS=gcp-service-account.json
TRYON_MODEL=gemini-2.5-flash-image

# Media storage (private GCS bucket)
# Supported values: gcs
MEDIA_STORAGE_BACKEND=gcs
# Deprecated compatibility toggle; archival now follows MEDIA_STORAGE_BACKEND.
MEDIA_ARCHIVE_ENABLED=true
GCS_BUCKET_NAME=
GCS_MEDIA_PREFIX=v1
GCS_SIGNED_URL_TTL_SECONDS=900

# Replicate
REPLICATE_API_TOKEN=
REPLICATE_MODEL=

# Seedream
SEEDREAM_API_KEY=
SEEDREAM_MODEL=
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_TIMEOUT_SECONDS=90

# Admin API (keep this secret)
ADMIN_API_KEY=optimo-admin-key-change-in-prod

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Path to SMPL .pkl model files
SMPL_MODEL_DIR=data/body_models

# Measurement backend mode: local_smpl or shapy_remote
REGRESSOR_BACKEND=local_smpl

# SHAPY remote service (used when REGRESSOR_BACKEND=shapy_remote)
SHAPY_SERVICE_URL=
SHAPY_API_KEY=
SHAPY_TIMEOUT=60

# Consented research retention (storefront step-1 checkbox)
RESEARCH_CONSENT_REQUIRED=true
RESEARCH_CONSENT_VERSION=v1
RESEARCH_RETENTION_DAYS=365

# Usage Governance
WEEKLY_TRYON_LIMIT_DEFAULT=10
ANON_WEEKLY_TRYON_LIMIT=1
CREDITS_PER_GENERATION=4
# Fallback per-credit overage rate (USD) only when a plan has no explicit overage price.
OVERAGE_USD_PER_CREDIT=0.035
OVERAGE_DAILY_THRESHOLD_USD=10
OVERAGE_USAGE_CAP_USD=10000
OVERAGE_SETTLEMENT_ENABLED=true
OVERAGE_SETTLEMENT_INTERVAL_MINUTES=15
# Local settlement cut-off in each store timezone (24h HH:MM)
OVERAGE_SETTLEMENT_LOCAL_TIME=23:55

# Storefront Proxy Trust
WIDGET_PROXY_SHARED_SECRET=
WIDGET_PROXY_MAX_SKEW_SECONDS=300

# Storefront Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WIDGET_SESSIONS_PER_MINUTE=30
RATE_LIMIT_TRYON_GENERATE_PER_MINUTE=12
RATE_LIMIT_TRYON_STUDIO_PER_MINUTE=8
